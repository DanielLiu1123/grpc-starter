<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE generatorConfiguration PUBLIC
        "-//mybatis.org//DTD MyBatis Generator Configuration 1.0//EN"
        "http://mybatis.org/dtd/mybatis-generator-config_1_0.dtd">
<!-- use mbGenerator: https://moego.atlassian.net/wiki/spaces/~628455ecc217e200698cdccd/pages/79233368 -->
<generatorConfiguration>
    <context id="H2">
        <commentGenerator>
            <property name="suppressDate" value="true"/>
            <property name="addRemarkComments" value="true"/>
        </commentGenerator>

        <jdbcConnection
                driverClass="com.mysql.cj.jdbc.Driver"
                connectionURL="jdbc:mysql://localhost:3306/testdb"
                userId="root"
                password="root"
        >
        </jdbcConnection>

        <javaModelGenerator
                targetPackage="grpcstarter.example.entity"
                targetProject="examples/quick-start/src/main/java"
        >
        </javaModelGenerator>

        <javaClientGenerator
                targetPackage="grpcstarter.example.mapper"
                targetProject="examples/quick-start/src/main/java"
        >
        </javaClientGenerator>

        <table tableName="pet">
            <generatedKey column="id" sqlStatement="MySQL" identity="true"/>
            <columnOverride column="status" javaType="grpcstarter.example.entity.Status" typeHandler="org.apache.ibatis.type.EnumOrdinalTypeHandler">
                <property name="forceJavaTypeIntoMapping" value="true"/>
            </columnOverride>
        </table>
    </context>
</generatorConfiguration>
